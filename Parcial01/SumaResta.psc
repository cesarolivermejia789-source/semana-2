Algoritmo SumaResta
    Definir num1, num2, suma, resta Como Real
	
    Escribir "Ingresa el primer número: "
    Leer num1
	
    Escribir "Ingresa el segundo número: "
    Leer num2
	
    suma <- num1 + num2
    resta <- num1 - num2
	
    Escribir "La suma de los números es: ", suma
    Escribir "La resta de los números es: ", resta
FinAlgoritmo
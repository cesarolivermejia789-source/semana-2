Algoritmo SolicitarNumero
    Definir numero Como Entero
    
    Escribir "Ingrese un número entre 1 y 10:"
    Leer numero
    
    Mientras numero >= 1 Y numero <= 10 Hacer
        Escribir "Número válido: ", numero
        Escribir "Ingrese otro número entre 1 y 10:"
        Leer numero
    FinMientras
    
    Escribir "Número inválido ingresado"
    
FinAlgoritmo